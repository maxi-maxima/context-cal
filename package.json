{
  "name": "context-cal",
  "version": "0.1.0",
  "description": "A local-first context budget auditor for AI coding agents.",
  "type": "module",
  "bin": {
    "context-cal": "./dist/cli.js"
  },
  "files": [
    "dist",
    "templates",
    "README.md",
    "README.zh-CN.md",
    "CHANGELOG.md",
    "CHANGELOG.zh-CN.md",
    "CONTRIBUTING.md",
    "CONTRIBUTING.zh-CN.md",
    "SECURITY.md",
    "SECURITY.zh-CN.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "node -e \"fs.rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.test.json",
    "check": "npm run lint && npm run test && npm run typecheck && npm run build",
    "prepack": "npm run check"
  },
  "keywords": [
    "ai-agent",
    "context-engineering",
    "agents-md",
    "claude-code",
    "codex",
    "cursor",
    "mcp",
    "cli",
    "devtools"
  ],
  "author": "maxi-maxima",
  "license": "MIT",
  "dependencies": {
    "commander": "^14.0.2",
    "fast-glob": "^3.3.3",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^24.10.2",
    "eslint": "^9.39.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.1",
    "vitest": "^4.0.15"
  },
  "engines": {
    "node": ">=20"
  }
}
